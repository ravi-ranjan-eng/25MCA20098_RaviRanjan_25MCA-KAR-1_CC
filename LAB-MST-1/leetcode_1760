def minimumPenalty(nums,maxOperations):
    left=1
    right=max(nums)
    while left<right:
        mid=(left+right)//2
        operations=0
        for balls in nums:
            operations+=(balls-1)//mid
        if operations>maxOperations:
            left=mid+1
        else:
            right=mid
    return left
nums=list(map(int,input().split()))
maxOperations=int(input())
print(minimumPenalty(nums,maxOperations))
